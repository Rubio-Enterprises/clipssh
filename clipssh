#!/usr/bin/env bash
#
# clipssh - Send clipboard screenshot to remote SSH host
# https://github.com/strubio-ray/clipssh
#

# Enable errexit only when the script is the program's entry point.
# Tests source this file and don't want errexit leaking into their shell.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -e
fi

VERSION="%%VERSION%%"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Config file (XDG-compliant)
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/clipssh"
CONFIG_FILE="$CONFIG_DIR/config"
STATE_FILE="$CONFIG_DIR/state"

# Defaults for option globals set by parse_args. Pre-initialised at script
# scope so parse_args is safe to call from a freshly-sourced shell (tests).
SSH_OPTS=()
FILE_SOURCE=""
REMOTE_DIR_OVERRIDE=""
PRINT_ONLY=0
WATCH=0
WATCH_INTERVAL=2
HOST_FROM_CLI=""

usage() {
    echo "Usage: clipssh [user@host] [options]"
    echo "       clipssh config [set|get|list]"
    echo "       clipssh setup"
    echo ""
    echo "Send clipboard screenshot (or a file) to a remote SSH host and copy the"
    echo "resulting path to your local clipboard."
    echo ""
    echo "Arguments:"
    echo "  user@host                   Remote host"
    echo ""
    echo "Commands:"
    echo "  config set <key> <value>    Set a config value"
    echo "  config get <key>            Get a config value"
    echo "  config list                 Show all settings with sources"
    echo "  setup                       Interactive first-run setup"
    echo ""
    echo "Options:"
    echo "  -f, --file PATH             Upload PATH instead of reading the clipboard"
    echo "  -r, --remote-dir DIR        Override remote upload directory"
    echo "  -p, --port PORT             SSH port (passed through to ssh)"
    echo "  -i, --identity FILE         SSH identity file (passed through to ssh)"
    echo "  -o OPTION                   SSH -o option, may repeat"
    echo "  -P, --print-only            Print remote path; do not overwrite clipboard"
    echo "  -w, --watch                 Watch clipboard and upload new images as they appear"
    echo "      --interval SECONDS      Poll interval for --watch (default: 2)"
    echo "  -h, --help                  Show this help"
    echo "  -v, --version               Show version"
    echo ""
    echo "Environment (overrides config file):"
    echo "  CLIPSSH_HOST                Remote host"
    echo "  CLIPSSH_REMOTE_DIR          Remote directory for uploads"
    echo ""
    echo "Config keys: host, remote_dir"
    echo "Config file: $CONFIG_FILE"
    echo ""
    echo "Example:"
    echo "  clipssh setup"
    echo "  clipssh user@server -p 2222 -i ~/.ssh/id_ed25519"
    echo "  clipssh -f ~/Desktop/diagram.png"
    echo "  clipssh --watch"
}

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

success() {
    echo -e "${GREEN}$1${NC}"
}

config_get() {
    local key="$1"
    if [[ -f "$CONFIG_FILE" ]]; then
        grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | tail -1 | cut -d= -f2-
    fi
}

config_set() {
    local key="$1" value="$2"
    mkdir -p "$CONFIG_DIR"
    # Drop any existing line for $key and append a fresh one. Rewriting via
    # grep+printf (rather than sed s|...|...|) keeps values containing sed
    # metacharacters — | & \ — intact. The wizard now feeds arbitrary user
    # input through here, so this matters.
    if [[ -f "$CONFIG_FILE" ]] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        local tmp="${CONFIG_FILE}.tmp"
        grep -v "^${key}=" "$CONFIG_FILE" > "$tmp" || true
        printf '%s=%s\n' "$key" "$value" >> "$tmp"
        mv "$tmp" "$CONFIG_FILE"
    else
        printf '%s=%s\n' "$key" "$value" >> "$CONFIG_FILE"
    fi
}

config_list() {
    echo "Config file: $CONFIG_FILE"
    echo ""
    for key in host remote_dir; do
        local file_val env_var default effective source
        file_val=$(config_get "$key")
        case "$key" in
            host)       env_var="${CLIPSSH_HOST:-}"; default="" ;;
            remote_dir) env_var="${CLIPSSH_REMOTE_DIR:-}"; default="/tmp" ;;
        esac
        if [[ -n "$env_var" ]]; then
            effective="$env_var"; source="env"
        elif [[ -n "$file_val" ]]; then
            effective="$file_val"; source="config"
        elif [[ -n "$default" ]]; then
            effective="$default"; source="default"
        else
            effective="(not set)"; source=""
        fi
        printf "  %-12s = %s" "$key" "$effective"
        [[ -n "$source" ]] && printf "  (%s)" "$source"
        echo ""
    done
}

handle_config_command() {
    case "${1:-}" in
        set)
            [[ -z "${2:-}" || -z "${3:-}" ]] && error "Usage: clipssh config set <key> <value>"
            config_set "$2" "$3"
            success "Set $2 = $3"
            ;;
        get)
            [[ -z "${2:-}" ]] && error "Usage: clipssh config get <key>"
            local val; val=$(config_get "$2")
            if [[ -z "$val" ]]; then
                echo "(not set)" >&2
                exit 1
            fi
            echo "$val"
            ;;
        list|"")
            config_list
            ;;
        *)
            error "Unknown config command: $1. Use: set, get, list"
            ;;
    esac
}

# Side effects (all globals): HOST, FILE_SOURCE, REMOTE_DIR_OVERRIDE,
# PRINT_ONLY, WATCH, WATCH_INTERVAL, and the SSH_OPTS array. SSH_OPTS is
# accumulated rather than overwritten so callers can pass -o repeatedly.
parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "clipssh $VERSION"
                exit 0
                ;;
            -p|--port)
                [[ -z "${2:-}" ]] && error "Missing value for $1"
                SSH_OPTS+=(-p "$2")
                shift 2
                ;;
            -i|--identity)
                [[ -z "${2:-}" ]] && error "Missing value for $1"
                SSH_OPTS+=(-i "$2")
                shift 2
                ;;
            -o)
                [[ -z "${2:-}" ]] && error "Missing value for $1"
                SSH_OPTS+=(-o "$2")
                shift 2
                ;;
            -f|--file)
                [[ -z "${2:-}" ]] && error "Missing value for $1"
                FILE_SOURCE="$2"
                shift 2
                ;;
            -r|--remote-dir)
                [[ -z "${2:-}" ]] && error "Missing value for $1"
                REMOTE_DIR_OVERRIDE="$2"
                shift 2
                ;;
            -P|--print-only)
                PRINT_ONLY=1
                shift
                ;;
            -w|--watch)
                WATCH=1
                shift
                ;;
            --interval)
                [[ -z "${2:-}" ]] && error "Missing value for --interval"
                WATCH_INTERVAL="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                HOST="$1"
                HOST_FROM_CLI="$1"
                shift
                ;;
        esac
    done
}

# Precedence: CLI arg > env var > config file.
resolve_host() {
    HOST="${HOST:-${CLIPSSH_HOST:-$(config_get host)}}"
    if [[ -z "$HOST" ]]; then
        error "No host specified. Use: clipssh user@host or run: clipssh config set host user@host"
    fi
}

detect_clipboard_tool() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        if ! command -v clipssh-paste &> /dev/null; then
            error "clipssh-paste not found. Install with: brew install strubio-ray/tap/clipssh"
        fi
    elif [[ "$OSTYPE" == "linux"* ]]; then
        if command -v xclip &> /dev/null; then
            PASTE_CMD="xclip -selection clipboard -target image/png -o"
        elif command -v wl-paste &> /dev/null; then
            PASTE_CMD="wl-paste --type image/png"
        else
            error "No clipboard tool found. Install xclip or wl-clipboard"
        fi
    else
        error "Unsupported OS: $OSTYPE"
    fi
}

extract_clipboard_image() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        if clipssh-paste > "$TEMP_FILE" 2>"$STDERR_FILE"; then
            SOURCE_LINE=$(tail -1 "$STDERR_FILE")
        else
            error "$(tail -1 "$STDERR_FILE")"
        fi
    else
        if extract_linux_file_reference; then
            :
        elif extract_linux_text_path; then
            :
        elif ! $PASTE_CMD > "$TEMP_FILE" 2>/dev/null; then
            error "No image in clipboard. Take a screenshot first"
        fi
    fi

    if [[ ! -s "$TEMP_FILE" ]]; then
        error "Clipboard image is empty"
    fi
}

# Mirrors compute_remote_filename's view of the clipboard: a synthesized
# "source:file:<path>" line carries the basename through into the filename.
load_from_file_source() {
    local path="$1"
    [[ -f "$path" ]] || error "File not found: $path"
    [[ -r "$path" ]] || error "File not readable: $path"
    [[ -s "$path" ]] || error "File is empty: $path"
    cp -- "$path" "$TEMP_FILE"
    SOURCE_LINE="source:file:$path"
}

# Linux clipboard contains a file URI (Nautilus / Dolphin / Files "Copy"). xclip
# is the only tool that can read text/uri-list reliably across desktops; if it's
# absent we silently fall back to other detection paths in extract_clipboard_image.
extract_linux_file_reference() {
    command -v xclip >/dev/null 2>&1 || return 1
    local targets uri path
    targets=$(xclip -selection clipboard -t TARGETS -o 2>/dev/null) || return 1
    grep -qx 'text/uri-list' <<<"$targets" || return 1
    uri=$(xclip -selection clipboard -t text/uri-list -o 2>/dev/null \
        | grep -v '^#' | head -n1 | tr -d '\r')
    [[ "$uri" == file://* ]] || return 1
    # Strip file:// (and optional hostname) and URL-decode any %XX escapes.
    path="${uri#file://}"
    path="${path#localhost}"
    path=$(printf '%b' "${path//%/\\x}")
    is_supported_image_path "$path" || return 1
    cp -- "$path" "$TEMP_FILE" 2>/dev/null || return 1
    SOURCE_LINE="source:file:$path"
    return 0
}

# Linux clipboard contains a plain text path (right-click -> Copy as Path).
# Mirrors clipssh-paste's tryTextPath: single line, starts with / or ~, image ext.
extract_linux_text_path() {
    local text
    text=$(get_linux_clipboard_text) || return 1
    text=$(trim_whitespace "$text")
    [[ -z "$text" ]] && return 1
    [[ "$text" == *$'\n'* ]] && return 1
    # Match-paired only: the old `^[\'\"](.+)[\'\"]$` accepted mismatched
    # quotes like `"foo'`. Bash regex has no backreferences, so we test the
    # two cases explicitly.
    if [[ "$text" =~ ^\"(.+)\"$ ]] || [[ "$text" =~ ^\'(.+)\'$ ]]; then
        text="${BASH_REMATCH[1]}"
    fi
    [[ "$text" == /* || "$text" == \~* ]] || return 1
    local expanded="${text/#\~/$HOME}"
    is_supported_image_path "$expanded" || return 1
    [[ -f "$expanded" ]] || return 1
    cp -- "$expanded" "$TEMP_FILE" 2>/dev/null || return 1
    SOURCE_LINE="source:path:$expanded"
    return 0
}

get_linux_clipboard_text() {
    if command -v xclip >/dev/null 2>&1; then
        xclip -selection clipboard -o 2>/dev/null
    elif command -v wl-paste >/dev/null 2>&1; then
        wl-paste --type text/plain 2>/dev/null
    else
        return 1
    fi
}

trim_whitespace() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

# tr is used instead of ${var,,} because the latter requires bash 4+ and
# macOS still ships bash 3.2 as /bin/bash.
is_supported_image_path() {
    local p="$1" ext
    ext="${p##*.}"
    ext=$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')
    case "$ext" in
        png|jpg|jpeg|gif|tiff|bmp|webp) return 0 ;;
        *) return 1 ;;
    esac
}

# Replaces any character outside [A-Za-z0-9._-] with '_'. Applied to the
# clipboard-derived basename before it's interpolated into the remote shell
# string in upload_to_remote — defense in depth against a clipboard payload
# that contains shell metacharacters.
sanitize_filename() {
    local input="$1"
    echo "${input//[^A-Za-z0-9._-]/_}"
}

compute_remote_filename() {
    local timestamp="$1" source_line="${2:-}"
    local base
    case "$source_line" in
        source:file:*|source:path:*)
            local original_name="${source_line#source:*:}"
            original_name="${original_name##*/}"
            base="${original_name%.*}"
            ;;
        *)
            base="clipboard"
            ;;
    esac
    echo "$(sanitize_filename "$base")-${timestamp}.png"
}

# UTC ISO-ish stamp (20260513T142701Z). Human-readable, sorts lexically, no
# colons that would confuse shells / scp. Falls back to epoch seconds if the
# system `date` chokes on the format spec (unlikely outside busybox).
make_timestamp() {
    date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%s
}

format_source_label() {
    case "${1:-}" in
        source:image) printf 'screenshot' ;;
        source:file:*) printf 'file: %s' "${1#source:file:}" ;;
        source:path:*) printf 'path: %s' "${1#source:path:}" ;;
        *) printf 'clipboard' ;;
    esac
}

# Bytes -> human string. wc -c is portable; numfmt isn't on macOS by default.
# LC_ALL=C pins awk's %f to a `.` decimal point — gawk otherwise honours the
# user's LC_NUMERIC and would emit `1,5 KB` under e.g. de_DE.
human_size() {
    local bytes="$1"
    if (( bytes < 1024 )); then
        printf '%d B' "$bytes"
    elif (( bytes < 1024 * 1024 )); then
        LC_ALL=C awk -v b="$bytes" 'BEGIN { printf "%.1f KB", b/1024 }'
    else
        LC_ALL=C awk -v b="$bytes" 'BEGIN { printf "%.1f MB", b/(1024*1024) }'
    fi
}

# Precedence: --remote-dir flag > env var > config file > /tmp.
# Note: remote_dir is user-controlled (config / env / flag) and is intentionally
# evaluated on the remote shell to expand `~`. It is treated as trusted.
resolve_remote_dir() {
    local dir="${REMOTE_DIR_OVERRIDE:-${CLIPSSH_REMOTE_DIR:-$(config_get remote_dir)}}"
    echo "${dir:-/tmp}"
}

upload_to_remote() {
    local host="$1" remote_dir="$2" remote_filename="$3" local_file="$4"
    local remote_path err_file
    err_file=$(mktemp)
    # SC2029: $remote_dir interpolates locally so the remote shell can run
    # `eval echo` and expand ~. $remote_filename is sanitized in
    # compute_remote_filename so it can't carry shell metacharacters.
    # SSH_OPTS expands to user-supplied -p/-i/-o flags, empty by default.
    # shellcheck disable=SC2029
    remote_path=$(ssh "${SSH_OPTS[@]}" "$host" "
        DIR=\$(eval echo \"$remote_dir\")
        PATH_FULL=\"\$DIR/${remote_filename}\"
        mkdir -p \"\$DIR\" && cat > \"\$PATH_FULL\" && echo \"\$PATH_FULL\"
    " < "$local_file" 2>"$err_file") || true
    if [[ -z "$remote_path" ]]; then
        local detail; detail=$(tail -1 "$err_file" 2>/dev/null || true)
        rm -f "$err_file"
        if [[ -n "$detail" ]]; then
            error "Failed to upload to $host: $detail"
        fi
        error "Failed to upload to $host"
    fi
    rm -f "$err_file"
    echo "$remote_path"
}

copy_to_local_clipboard() {
    local value="$1"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo -n "$value" | pbcopy
    elif command -v xclip &> /dev/null; then
        echo -n "$value" | xclip -selection clipboard
    elif command -v wl-copy &> /dev/null; then
        echo -n "$value" | wl-copy
    fi
}

# Acquire one image into $TEMP_FILE / $SOURCE_LINE — from disk if --file
# was given, otherwise from the clipboard. Returns nonzero on failure;
# callers (the single-shot path) error out, watch mode just skips.
acquire_image() {
    SOURCE_LINE=""
    : > "$TEMP_FILE"
    : > "$STDERR_FILE"
    if [[ -n "$FILE_SOURCE" ]]; then
        load_from_file_source "$FILE_SOURCE"
    else
        extract_clipboard_image
    fi
}

upload_and_report() {
    local timestamp remote_filename remote_dir remote_path bytes
    timestamp=$(make_timestamp)
    remote_filename=$(compute_remote_filename "$timestamp" "$SOURCE_LINE")
    remote_dir=$(resolve_remote_dir)
    remote_path=$(upload_to_remote "$HOST" "$remote_dir" "$remote_filename" "$TEMP_FILE")

    if [[ "$PRINT_ONLY" -eq 1 ]]; then
        echo "$remote_path"
        return 0
    fi

    copy_to_local_clipboard "$remote_path"
    bytes=$(wc -c <"$TEMP_FILE" | tr -d ' ')
    success "Uploaded: $remote_path ($(human_size "$bytes"), $(format_source_label "$SOURCE_LINE"))"
    echo "Path copied to clipboard - paste it directly"
}

# sha1sum is GNU coreutils; macOS only ships `shasum` (Perl). Either gives us
# a stable fingerprint of the temp file — we don't care which one runs.
watch_hash() {
    if command -v sha1sum >/dev/null 2>&1; then
        sha1sum "$1" 2>/dev/null | cut -d' ' -f1
    else
        shasum "$1" 2>/dev/null | cut -d' ' -f1
    fi
}

# Polls the clipboard at $WATCH_INTERVAL seconds and uploads each new image.
# Skips repeats by tracking the previous upload's SHA-1.
#
# Robustness: acquire_image / upload_and_report can both call error() which
# exits. We run them inside a subshell so the exit terminates the iteration,
# not the whole watch. The subshell stashes the upload's hash in $HASH_FILE
# (always, even on a failed upload) so the parent can advance last_hash —
# this prevents the loop from spamming retries of a doomed upload until the
# user copies something new.
watch_loop() {
    local last_hash="" interval="${WATCH_INTERVAL:-2}"
    success "Watching clipboard on $HOST (interval ${interval}s). Ctrl-C to stop."
    while true; do
        : > "$HASH_FILE"
        (
            # Suppress acquire's stderr — "No image in clipboard" is the
            # routine case when the clipboard holds text. Upload errors are
            # left visible so real failures don't disappear.
            acquire_image 2>/dev/null
            [[ -s "$TEMP_FILE" ]] || exit 0
            local hash; hash=$(watch_hash "$TEMP_FILE")
            [[ -n "$hash" && "$hash" != "$last_hash" ]] || exit 0
            printf '%s' "$hash" > "$HASH_FILE"
            upload_and_report
        ) || true
        if [[ -s "$HASH_FILE" ]]; then
            last_hash=$(<"$HASH_FILE")
        fi
        sleep "$interval"
    done
}

# Increments a counter of consecutive CLI-arg invocations for the same host
# while nothing is saved in the config. After three uses we nudge the user
# to persist it; resets if the host changes or once they save anything.
maybe_suggest_save_host() {
    local cli_host="$1"
    [[ -z "$cli_host" ]] && return 0
    [[ -n "$(config_get host)" ]] && return 0
    mkdir -p "$CONFIG_DIR" 2>/dev/null || return 0
    local prev_host="" prev_count=0
    if [[ -f "$STATE_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$STATE_FILE" 2>/dev/null || true
    fi
    if [[ "$prev_host" != "$cli_host" ]]; then
        prev_count=0
    fi
    prev_count=$(( prev_count + 1 ))
    printf 'prev_host=%q\nprev_count=%d\n' "$cli_host" "$prev_count" > "$STATE_FILE"
    if (( prev_count == 3 )); then
        echo "Tip: run 'clipssh config set host $cli_host' to skip the argument next time." >&2
    fi
}

# Bails out gracefully if we don't have a tty (e.g. piped, non-interactive
# CI). The wizard saves whatever the user typed, then returns so main() can
# continue with the freshly-written config.
run_setup_wizard() {
    if [[ ! -t 0 || ! -t 1 ]]; then
        error "clipssh setup requires an interactive terminal. Run: clipssh config set host user@host"
    fi
    success "clipssh setup"
    echo "Press Enter to accept the [default] in brackets."
    echo ""

    local host_default; host_default=$(config_get host)
    local host_input
    read -r -p "Remote host (user@server) [${host_default:-required}]: " host_input
    host_input="${host_input:-$host_default}"
    if [[ -z "$host_input" ]]; then
        error "Setup cancelled: a host is required."
    fi
    config_set host "$host_input"

    local dir_default; dir_default=$(config_get remote_dir)
    local dir_input
    read -r -p "Remote upload directory [${dir_default:-/tmp}]: " dir_input
    dir_input="${dir_input:-${dir_default:-/tmp}}"
    config_set remote_dir "$dir_input"

    echo ""
    success "Saved to $CONFIG_FILE."
    local probe
    read -r -p "Test SSH connection to $host_input now? [Y/n] " probe
    probe="${probe:-y}"
    case "$probe" in
        y|Y|yes|YES|Yes) probe="y" ;;
        *) probe="n" ;;
    esac
    if [[ "$probe" == "y" ]]; then
        if ssh -o BatchMode=yes -o ConnectTimeout=5 "$host_input" true 2>/dev/null; then
            success "SSH connection OK."
        else
            echo "Could not authenticate non-interactively. You may need to set up keys" >&2
            echo "or you'll be prompted for a password each run." >&2
        fi
    fi
}

# True when nothing on the command line or environment suggests a non-interactive
# intent — no host yet, no one-shot flags. Factored out from should_offer_setup
# so it can be unit-tested without faking a TTY.
setup_preconditions_met() {
    [[ -z "${HOST:-}" ]] || return 1
    [[ -z "${CLIPSSH_HOST:-}" ]] || return 1
    [[ -z "$(config_get host)" ]] || return 1
    # Any explicit flag means the user expects an action, not a prompt.
    [[ "$PRINT_ONLY" -eq 0 && "$WATCH" -eq 0 && -z "$FILE_SOURCE" ]] || return 1
    [[ "${#SSH_OPTS[@]}" -eq 0 && -z "$REMOTE_DIR_OVERRIDE" ]] || return 1
    return 0
}

should_offer_setup() {
    setup_preconditions_met || return 1
    [[ -t 0 && -t 1 ]] || return 1
    return 0
}

main() {
    case "${1:-}" in
        config)
            shift
            handle_config_command "$@"
            exit 0
            ;;
        setup)
            run_setup_wizard
            exit 0
            ;;
    esac

    parse_args "$@"

    if should_offer_setup; then
        echo "No host configured. Running first-time setup."
        echo "(Tip: 'clipssh setup' rerunnable any time; Ctrl-C to skip.)"
        echo ""
        run_setup_wizard
        echo ""
    fi

    resolve_host
    maybe_suggest_save_host "${HOST_FROM_CLI:-}"
    # --file bypasses clipboard read entirely. --print-only still needs the
    # read side; only the write side (copy_to_local_clipboard) is skipped.
    if [[ -z "$FILE_SOURCE" ]]; then
        detect_clipboard_tool
    fi

    TEMP_FILE=$(mktemp).png
    STDERR_FILE=$(mktemp)
    HASH_FILE=$(mktemp)
    trap 'rm -f "$TEMP_FILE" "$STDERR_FILE" "$HASH_FILE"' EXIT

    if [[ "$WATCH" -eq 1 ]]; then
        watch_loop
        exit 0
    fi

    acquire_image
    upload_and_report
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi

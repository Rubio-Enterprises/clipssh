#!/usr/bin/env bash
#
# clipssh - Send clipboard screenshot to remote SSH host
# https://github.com/strubio-ray/clipssh
#

set -e

VERSION="%%VERSION%%"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Config file (XDG-compliant)
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/clipssh"
CONFIG_FILE="$CONFIG_DIR/config"

usage() {
    echo "Usage: clipssh [user@host] [options]"
    echo "       clipssh config [set|get|list]"
    echo ""
    echo "Send clipboard screenshot to remote SSH host and copy path to clipboard."
    echo ""
    echo "Arguments:"
    echo "  user@host                   Remote host"
    echo ""
    echo "Commands:"
    echo "  config set <key> <value>    Set a config value"
    echo "  config get <key>            Get a config value"
    echo "  config list                 Show all settings with sources"
    echo ""
    echo "Options:"
    echo "  -h, --help                  Show this help"
    echo "  -v, --version               Show version"
    echo "      --capture               (macOS only) Interactively capture a screen region,"
    echo "                              then upload it. Cancel with Esc."
    echo ""
    echo "Environment (overrides config file):"
    echo "  CLIPSSH_HOST                Remote host"
    echo "  CLIPSSH_REMOTE_DIR          Remote directory for uploads"
    echo ""
    echo "Config keys: host, remote_dir"
    echo "Config file: $CONFIG_FILE"
    echo ""
    echo "Example:"
    echo "  clipssh config set host user@myserver"
    echo "  clipssh config set remote_dir ~/.vibetunnel/control/uploads"
    echo "  clipssh"
}

# Emit a native macOS notification. No-op on Linux.
# Uses osascript with the message passed via environment variable to avoid
# AppleScript string-escaping issues with paths containing quotes/backslashes.
notify() {
    local title="$1" message="$2"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        CLIPSSH_NOTIFY_MSG="$message" CLIPSSH_NOTIFY_TITLE="$title" \
            osascript \
                -e 'display notification (system attribute "CLIPSSH_NOTIFY_MSG") with title (system attribute "CLIPSSH_NOTIFY_TITLE")' \
                >/dev/null 2>&1 || true
    fi
}

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    notify "clipssh" "$1"
    exit 1
}

success() {
    echo -e "${GREEN}$1${NC}"
    notify "clipssh" "$1"
}

config_get() {
    local key="$1"
    if [[ -f "$CONFIG_FILE" ]]; then
        grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | tail -1 | cut -d= -f2-
    fi
}

config_set() {
    local key="$1" value="$2"
    mkdir -p "$CONFIG_DIR"
    if [[ -f "$CONFIG_FILE" ]] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        local tmp="${CONFIG_FILE}.tmp"
        sed "s|^${key}=.*|${key}=${value}|" "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
    else
        echo "${key}=${value}" >> "$CONFIG_FILE"
    fi
}

config_list() {
    echo "Config file: $CONFIG_FILE"
    echo ""
    for key in host remote_dir; do
        local file_val env_var default effective source
        file_val=$(config_get "$key")
        case "$key" in
            host)       env_var="${CLIPSSH_HOST:-}"; default="" ;;
            remote_dir) env_var="${CLIPSSH_REMOTE_DIR:-}"; default="/tmp" ;;
        esac
        if [[ -n "$env_var" ]]; then
            effective="$env_var"; source="env"
        elif [[ -n "$file_val" ]]; then
            effective="$file_val"; source="config"
        elif [[ -n "$default" ]]; then
            effective="$default"; source="default"
        else
            effective="(not set)"; source=""
        fi
        printf "  %-12s = %s" "$key" "$effective"
        [[ -n "$source" ]] && printf "  (%s)" "$source"
        echo ""
    done
}

# Parse arguments
case "${1:-}" in
    config)
        shift
        case "${1:-}" in
            set)
                [[ -z "${2:-}" || -z "${3:-}" ]] && error "Usage: clipssh config set <key> <value>"
                config_set "$2" "$3"
                success "Set $2 = $3"
                ;;
            get)
                [[ -z "${2:-}" ]] && error "Usage: clipssh config get <key>"
                config_get "$2"
                ;;
            list|"")
                config_list
                ;;
            *)
                error "Unknown config command: $1. Use: set, get, list"
                ;;
        esac
        exit 0
        ;;
esac

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "clipssh $VERSION"
            exit 0
            ;;
        --capture)
            CAPTURE_MODE=1
            shift
            ;;
        -*)
            error "Unknown option: $1"
            ;;
        *)
            HOST="$1"
            shift
            ;;
    esac
done

# --capture is macOS-only
if [[ "${CAPTURE_MODE:-0}" == "1" && "$OSTYPE" != "darwin"* ]]; then
    error "--capture is not supported on Linux (requires macOS screencapture)"
fi

# Determine host (CLI arg > env var > config file)
HOST="${HOST:-${CLIPSSH_HOST:-$(config_get host)}}"
if [[ -z "$HOST" ]]; then
    error "No host specified. Use: clipssh user@host or run: clipssh config set host user@host"
fi

# Check OS and clipboard tool
if [[ "$OSTYPE" == "darwin"* ]]; then
    if ! command -v clipssh-paste &> /dev/null; then
        error "clipssh-paste not found. Install with: brew install strubio-ray/tap/clipssh"
    fi
elif [[ "$OSTYPE" == "linux"* ]]; then
    if command -v xclip &> /dev/null; then
        PASTE_CMD="xclip -selection clipboard -target image/png -o"
    elif command -v wl-paste &> /dev/null; then
        PASTE_CMD="wl-paste --type image/png"
    else
        error "No clipboard tool found. Install xclip or wl-clipboard"
    fi
else
    error "Unsupported OS: $OSTYPE"
fi

# Create temp file for the payload we'll upload
TEMP_FILE=$(mktemp).png
trap "rm -f $TEMP_FILE" EXIT

if [[ "${CAPTURE_MODE:-0}" == "1" ]]; then
    # --capture mode: interactive region screenshot via screencapture.
    # Write directly to a tempfile (not the clipboard) to avoid races with
    # third-party clipboard managers. Cancel is detected by file absence/emptiness.

    if ! command -v screencapture &> /dev/null; then
        error "screencapture not found (this should never happen on macOS)"
    fi

    # screencapture -i returns 0 on both successful capture AND user cancel (Esc).
    # A non-zero exit indicates a genuine error (disk full, permission denied, etc.)
    # that we should surface explicitly. Cancel is distinguished below by whether
    # the tempfile ended up non-empty.
    SCREENCAP_STATUS=0
    /usr/sbin/screencapture -i "$TEMP_FILE" 2>/dev/null || SCREENCAP_STATUS=$?

    if [[ $SCREENCAP_STATUS -ne 0 ]]; then
        error "screencapture failed (exit $SCREENCAP_STATUS)"
    fi

    if [[ ! -s "$TEMP_FILE" ]]; then
        # User cancelled (Esc or clicked away). Exit silently with code 2,
        # distinct from success (0) and error (1), for scripting friendliness.
        exit 2
    fi

    SOURCE_LINE="source:capture"
else
    # Standard mode: extract image from clipboard.
    if [[ "$OSTYPE" == "darwin"* ]]; then
        STDERR_FILE=$(mktemp)
        trap "rm -f $TEMP_FILE $STDERR_FILE" EXIT
        if clipssh-paste > "$TEMP_FILE" 2>"$STDERR_FILE"; then
            SOURCE_LINE=$(tail -1 "$STDERR_FILE")
            rm -f "$STDERR_FILE"
        else
            error "$(tail -1 "$STDERR_FILE")"
        fi
    else
        if ! $PASTE_CMD > "$TEMP_FILE" 2>/dev/null; then
            error "No image in clipboard. Take a screenshot first"
        fi
    fi
fi

# Verify file has content
if [[ ! -s "$TEMP_FILE" ]]; then
    error "Clipboard image is empty"
fi

# Determine remote filename
TIMESTAMP=$(date +%s)
case "$SOURCE_LINE" in
    source:capture)
        # --capture mode: always a screenshot, use a dedicated prefix
        REMOTE_FILENAME="screenshot-${TIMESTAMP}.png"
        ;;
    source:file:*)
        ORIGINAL_PATH="${SOURCE_LINE#source:file:}"
        ORIGINAL_NAME=$(basename "$ORIGINAL_PATH")
        ORIGINAL_BASE="${ORIGINAL_NAME%.*}"
        REMOTE_FILENAME="${ORIGINAL_BASE}-${TIMESTAMP}.png"
        ;;
    source:path:*)
        ORIGINAL_PATH="${SOURCE_LINE#source:path:}"
        ORIGINAL_NAME=$(basename "$ORIGINAL_PATH")
        ORIGINAL_BASE="${ORIGINAL_NAME%.*}"
        REMOTE_FILENAME="${ORIGINAL_BASE}-${TIMESTAMP}.png"
        ;;
    *)
        REMOTE_FILENAME="clipboard-${TIMESTAMP}.png"
        ;;
esac

# Generate remote path (env var > config file > default)
REMOTE_DIR="${CLIPSSH_REMOTE_DIR:-$(config_get remote_dir)}"
REMOTE_DIR="${REMOTE_DIR:-/tmp}"

# Upload via SSH (~ is expanded by the remote shell using eval echo)
REMOTE_PATH=$(ssh "$HOST" "
    DIR=\$(eval echo \"$REMOTE_DIR\")
    PATH_FULL=\"\$DIR/${REMOTE_FILENAME}\"
    mkdir -p \"\$DIR\" && cat > \"\$PATH_FULL\" && echo \"\$PATH_FULL\"
" < "$TEMP_FILE" 2>/dev/null) || true

if [[ -z "$REMOTE_PATH" ]]; then
    error "Failed to upload to $HOST"
fi

# Copy path to clipboard
if [[ "$OSTYPE" == "darwin"* ]]; then
    echo -n "$REMOTE_PATH" | pbcopy
elif command -v xclip &> /dev/null; then
    echo -n "$REMOTE_PATH" | xclip -selection clipboard
elif command -v wl-copy &> /dev/null; then
    echo -n "$REMOTE_PATH" | wl-copy
fi

success "Uploaded: $REMOTE_PATH"
echo "Path copied to clipboard - paste it directly"
